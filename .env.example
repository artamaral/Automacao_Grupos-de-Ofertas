APP_ENV=local
LOG_LEVEL=INFO

# Harness
DEFAULT_DRY_RUN=true
MAX_OFFERS_PER_RUN=5

# HTTP real deve permanecer false ate concluir o checklist de producao
ENABLE_REAL_HTTP=false

# Shopee GraphQL - preencher fora do git
SHOPEE_PARTNER_ID=
SHOPEE_SECRET_KEY=
SHOPEE_TRACKING_ID=
SHOPEE_GRAPHQL_URL=https://open-api.affiliate.shopee.com.br/graphql
SHOPEE_OFFER_LIST_OPERATION=ShopOfferList
SHOPEE_OFFER_LIST_ROOT_FIELD=shopOfferV2
# SHOPEE_OFFER_LIST_QUERY_FILE=.data/shopee_offer_list.graphql

# Shopee REST legado - nao usado pelo fluxo principal atual
# SHOPEE_BASE_URL=https://example.com
# SHOPEE_SEARCH_PATH=/api/v2/product/search_item
# SHOPEE_SEARCH_PATH_CONFIRMED=false

# Amazon PA API - preencher fora do git
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=
AMAZON_REGION=BR
AMAZON_BASE_URL=https://example.com
AMAZON_SEARCH_PATH=/paapi5/searchitems

# Publicação real deve permanecer false até existir aprovação humana
ENABLE_REAL_PUBLISH=false
