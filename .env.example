APP_ENV=local
LOG_LEVEL=INFO

# Harness
DEFAULT_DRY_RUN=true
MAX_OFFERS_PER_RUN=5

# Shopee - preencher fora do git
SHOPEE_PARTNER_ID=
SHOPEE_SECRET_KEY=
SHOPEE_TRACKING_ID=

# Amazon PA API - preencher fora do git
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=
AMAZON_REGION=BR

# Publicação real deve permanecer false até existir aprovação humana
ENABLE_REAL_PUBLISH=false
