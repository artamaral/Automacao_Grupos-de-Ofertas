{
  "name": "ofertas-rodada-skeleton",
  "meta": {
    "templateCredsSetupCompleted": false,
    "description": "Esqueleto inicial do workflow operacional de ofertas para n8n. Ajustar paths, notificacoes e persistencia antes de uso real."
  },
  "active": false,
  "nodes": [
    {
      "id": "1",
      "name": "Trigger Rodada",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        0,
        0
      ],
      "parameters": {}
    },
    {
      "id": "2",
      "name": "Set Contexto Base",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        220,
        0
      ],
      "parameters": {
        "keepOnlySet": false,
        "values": {
          "string": [
            {
              "name": "profile",
              "value": "={{ $json.profile || 'feminino' }}"
            },
            {
              "name": "run_id",
              "value": "={{ $json.run_id || $now.toISO() }}"
            },
            {
              "name": "requested_by",
              "value": "={{ $json.requested_by || 'n8n' }}"
            },
            {
              "name": "notes",
              "value": "={{ $json.notes || '' }}"
            },
            {
              "name": "root_dir",
              "value": "<n8n-root>"
            },
            {
              "name": "app_dir",
              "value": "<n8n-root>/app/Automacao_Grupos-de-Ofertas"
            },
            {
              "name": "catalogs_dir",
              "value": "<n8n-root>/catalogs"
            },
            {
              "name": "data_dir",
              "value": "<n8n-root>/data"
            },
            {
              "name": "profile_catalog",
              "value": "={{ '<n8n-root>/catalogs/' + ($json.profile || 'feminino') + '/clean_catalog_rating_4_8_plus.csv' }}"
            },
            {
              "name": "profile_data_dir",
              "value": "={{ '<n8n-root>/data/' + ($json.profile || 'feminino') }}"
            }
          ]
        }
      }
    },
    {
      "id": "3",
      "name": "Validar Profile",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        0
      ],
      "parameters": {
        "language": "JavaScript",
        "jsCode": "const allowed = new Set(['feminino', 'mae-e-bebe', 'auto-e-moto']);\nconst profile = $json.profile;\nif (!allowed.has(profile)) {\n  return [{ json: { ...$json, status: 'error', error_code: 'invalid_profile', message: 'profile fora do contrato operacional' } }];\n}\nreturn [{ json: { ...$json, status: 'ok' } }];"
      }
    },
    {
      "id": "4",
      "name": "Profile OK?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        700,
        0
      ],
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.status }}",
              "operation": "equal",
              "value2": "ok"
            }
          ]
        }
      }
    },
    {
      "id": "5",
      "name": "Garantir Pasta do Profile",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        940,
        -120
      ],
      "parameters": {
        "command": "powershell -Command \"New-Item -ItemType Directory -Force -Path '{{$json.profile_data_dir}}' | Out-Null\""
      }
    },
    {
      "id": "6",
      "name": "Validar Catalogo Ativo",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        1180,
        -120
      ],
      "parameters": {
        "command": "powershell -ExecutionPolicy Bypass -File \"{{$json.app_dir}}\\scripts\\n8n\\validate_catalog.ps1\" -Profile \"{{$json.profile}}\" -RootDir \"{{$json.root_dir}}\""
      }
    },
    {
      "id": "7",
      "name": "Executar Prepare",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        1420,
        -120
      ],
      "parameters": {
        "command": "powershell -ExecutionPolicy Bypass -File \"{{$json.app_dir}}\\scripts\\n8n\\invoke_prepare.ps1\" -Profile \"{{$json.profile}}\" -RootDir \"{{$json.root_dir}}\""
      }
    },
    {
      "id": "8",
      "name": "Validar Artefatos Prepare",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        1660,
        -120
      ],
      "parameters": {
        "command": "powershell -Command \"$base='{{$json.profile_data_dir}}'; $required=@('offers.json','selection_state.json','copy_briefs.json','messages_preview.html','review_queue.json'); $missing=@(); foreach ($name in $required) { if (!(Test-Path (Join-Path $base $name))) { $missing += $name } }; if ($missing.Count -gt 0) { Write-Error ('MISSING=' + ($missing -join ',')); exit 1 }; Write-Output 'PREPARE_OUTPUTS_OK'\""
      }
    },
    {
      "id": "9",
      "name": "Publicar Pendencia de Revisao",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        1900,
        -120
      ],
      "parameters": {
        "keepOnlySet": false,
        "values": {
          "string": [
            {
              "name": "review_status",
              "value": "awaiting_human_review"
            },
            {
              "name": "review_queue_path",
              "value": "={{ $json.profile_data_dir + '/review_queue.json' }}"
            }
          ]
        }
      }
    },
    {
      "id": "10",
      "name": "Wait Review",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [
        2140,
        -120
      ],
      "parameters": {
        "resume": "manual"
      }
    },
    {
      "id": "11",
      "name": "Validar Queue Resolvida",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        2380,
        -120
      ],
      "parameters": {
        "command": "powershell -Command \"$path='{{$json.profile_data_dir}}\\review_queue.json'; $items=Get-Content $path -Raw | ConvertFrom-Json; $pending=@($items | Where-Object { $_.status -eq 'pending' }).Count; Write-Output ('PENDING_COUNT=' + $pending); if ($pending -gt 0) { exit 2 }\""
      }
    },
    {
      "id": "12",
      "name": "Executar Finalize",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        2620,
        -120
      ],
      "parameters": {
        "command": "powershell -ExecutionPolicy Bypass -File \"{{$json.app_dir}}\\scripts\\n8n\\invoke_finalize.ps1\" -Profile \"{{$json.profile}}\" -RootDir \"{{$json.root_dir}}\""
      }
    },
    {
      "id": "13",
      "name": "Validar Artefatos Finalize",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        2860,
        -120
      ],
      "parameters": {
        "command": "powershell -Command \"$base='{{$json.profile_data_dir}}'; $required=@('approved_messages.json','publication_manifest.json','dispatch_artifact.json','dispatch_report.json'); $missing=@(); foreach ($name in $required) { if (!(Test-Path (Join-Path $base $name))) { $missing += $name } }; if ($missing.Count -gt 0) { Write-Error ('MISSING=' + ($missing -join ',')); exit 1 }; Write-Output 'FINALIZE_OUTPUTS_OK'\""
      }
    },
    {
      "id": "14",
      "name": "Montar Resumo da Rodada",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        3100,
        -120
      ],
      "parameters": {
        "command": "powershell -Command \"$artifact = Get-Content '{{$json.profile_data_dir}}\\dispatch_artifact.json' -Raw | ConvertFrom-Json; $report = Get-Content '{{$json.profile_data_dir}}\\dispatch_report.json' -Raw | ConvertFrom-Json; $summary = [ordered]@{ status = 'ok'; profile = '{{$json.profile}}'; run_id = '{{$json.run_id}}'; dispatch_artifact_path = '{{$json.profile_data_dir}}/dispatch_artifact.json'; dispatch_report_path = '{{$json.profile_data_dir}}/dispatch_report.json'; total_targets = $artifact.summary.total_targets; total_available_messages = $artifact.summary.total_available_messages; total_selected_messages = $artifact.summary.total_selected_messages; total_blocked_targets = $artifact.summary.total_blocked_targets; total_dry_run = $report.summary.total_dry_run; mode = 'dry-run' }; $summary | ConvertTo-Json -Compress\""
      }
    },
    {
      "id": "15",
      "name": "Ler Dispatch Artifact",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        3100,
        20
      ],
      "parameters": {
        "command": "powershell -Command \"Get-Content '{{$json.profile_data_dir}}\\dispatch_artifact.json' -Raw\""
      }
    },
    {
      "id": "16",
      "name": "Ler Dispatch Report",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        3100,
        160
      ],
      "parameters": {
        "command": "powershell -Command \"Get-Content '{{$json.profile_data_dir}}\\dispatch_report.json' -Raw\""
      }
    },
    {
      "id": "17",
      "name": "Persistir Log da Rodada",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        3340,
        -120
      ],
      "parameters": {
        "keepOnlySet": false,
        "values": {
          "string": [
            {
              "name": "log_status",
              "value": "pending_persistence_implementation"
            }
          ]
        }
      }
    },
    {
      "id": "18",
      "name": "Notificar Conclusao",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        3580,
        -120
      ],
      "parameters": {
        "keepOnlySet": false,
        "values": {
          "string": [
            {
              "name": "notification_status",
              "value": "pending_notification_implementation"
            }
          ]
        }
      }
    }
  ],
