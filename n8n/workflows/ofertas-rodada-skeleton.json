    {
      "id": "13",
      "name": "Consolidar Janela",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3320, 0],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const rows = $input.all().map(item => item.json);\nreturn [{\n  json: {\n    run_id: rows[0]?.run_id || null,\n    total_profiles: rows.length,\n    profiles_processed: rows.map(row => row.profile),\n    processing_mode: 'per-profile-heavy-stages',\n    profiles: rows,\n  }\n}];"
      }
    },
