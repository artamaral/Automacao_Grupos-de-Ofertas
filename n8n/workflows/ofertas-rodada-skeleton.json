{
  "name": "ofertas-rodada-n8n-native-skeleton",
  "meta": {
    "templateCredsSetupCompleted": false,
    "description": "Workflow oficial n8n-native. Processa uma janela unica expandindo os profiles em items independentes; parse, score, selecao e copy rodam por profile e a consolidacao acontece no fim."
  },
  "active": false,
  "tags": [],
  "triggerCount": 0,
  "nodes": [
    {
      "id": "1",
      "name": "Trigger Rodada",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [0, 0],
      "parameters": {}
    },
    {
      "id": "2",
      "name": "Set Contexto Base",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [260, 0],
      "parameters": {
        "keepOnlySet": false,
        "values": {
          "string": [
            { "name": "profiles_csv", "value": "={{ $json.profiles_csv || 'feminino,mae-e-bebe,auto-e-moto' }}" },
            { "name": "run_id", "value": "={{ $json.run_id || $now.toFormat('yyyy-LL-dd') + '-janela-01' }}" },
            { "name": "requested_by", "value": "={{ $json.requested_by || 'n8n' }}" },
            { "name": "notes", "value": "={{ $json.notes || '' }}" },
            { "name": "allowed_targets_csv", "value": "={{ $json.allowed_targets_csv || '' }}" },
            { "name": "rules_spreadsheet_id", "value": "={{ $json.rules_spreadsheet_id || '16M0S-ipgQ9lOUqCtXTd1OC80I2emERCK8ByVllR06-E' }}" },
            { "name": "project_drive_folder_id", "value": "={{ $json.project_drive_folder_id || '1Ta1UWp88wrAp7GXnK3Hm8xO9xboO22WQ' }}" },
            { "name": "catalog_clean_folder_id", "value": "={{ $json.catalog_clean_folder_id || '1D8FJRdlcvPEccWXNAO7GNqPh4Bdu0HMa' }}" }
          ]
        }
      }
    },
    {
      "id": "3",
      "name": "Validar Contexto",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [520, 0],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const rawProfiles = $json.profiles_csv || '';\nconst profiles = rawProfiles.split(',').map(item => item.trim()).filter(Boolean);\nconst allowed = new Set(['feminino', 'mae-e-bebe', 'auto-e-moto']);\nif (!($json.rules_spreadsheet_id || '').trim()) throw new Error('rules_spreadsheet_id obrigatorio');\nif (!($json.project_drive_folder_id || '').trim()) throw new Error('project_drive_folder_id obrigatorio');\nif (profiles.length === 0) throw new Error('profiles_csv vazio');\nfor (const profile of profiles) { if (!allowed.has(profile)) throw new Error(`profile fora do contrato operacional: ${profile}`); }\nreturn [{ json: { ...$json, profiles, total_profiles: profiles.length } }];"
      }
    },
    {
      "id": "4",
      "name": "Expandir Profiles",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [800, 0],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const base = $json;\nreturn (base.profiles || []).map((profile) => ({\n  json: {\n    ...base,\n    profile,\n    processing_unit: 'profile',\n  }\n}));"
      }
    },
    {
      "id": "5",
      "name": "Ler Regras Google Sheets",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1080, 0],
      "parameters": {
        "keepOnlySet": false,
        "values": {
          "string": [
            { "name": "rules_status", "value": "pending_google_sheets_nodes" }
          ]
        }
      }
    },
    {
      "id": "6",
      "name": "Ler Catalog Registry",
      "type": "n8n-nodes-base.set",
